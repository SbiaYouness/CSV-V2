{
  "name": "concilio-root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "npm run build --prefix frontend && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "lint": "npm run lint --prefix frontend"
  },
  "dependencies": {
    "@google/genai": "latest",
    "express": "^4.19.2",
    "http-proxy-middleware": "^3.0.0",
    "vite": "^5.4.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3"
  }
}
